@echo off
title 照片生成器后端服务器

echo ====================================================
echo   正在启动后端服务器...
echo ====================================================

:: 1. 简单清理 3000 端口
echo 正在释放端口...
for /f "tokens=5" %%a in ('netstat -ano ^| findstr :3000') do (
    taskkill /F /PID %%a /T >nul 2>&1
)

:: 2. 启动服务器
echo ====================================================
echo   服务器启动中，请不要关闭此窗口
echo ====================================================
node server/index.js
pause